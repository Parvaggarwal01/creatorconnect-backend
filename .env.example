# MongoDB Connection
MONGO_URI=your_mongodb_connection_string

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration
# For development/testing: Leave EMAIL_SERVICE unset or set to 'ethereal' (uses fake SMTP)
# For production with Gmail: Set EMAIL_SERVICE=gmail and use App Password below
# EMAIL_SERVICE=gmail

# Gmail Configuration (only needed if EMAIL_SERVICE=gmail)
# Get App Password: https://myaccount.google.com/apppasswords
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_specific_password

# Server Port
PORT=3000
